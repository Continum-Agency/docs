{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Continum",
  "colors": {
    "primary": "#18181b",
    "light": "#52525b",
    "dark": "#09090b"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "SDK",
            "pages": [
              "sdk/installation",
              "sdk/configuration"
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "cli/overview",
              "cli/installation",
              "cli/authentication",
              "cli/commands",
              "cli/configuration",
              "cli/pattern-learning",
              "cli/team-deployment"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/zero-latency",
              "concepts/guardian",
              "concepts/mirror",
              "concepts/sandbox",
              "concepts/signal"
            ]
          }
          
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.continum.co",
          "icon": "chart-line"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/continum",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "https://continum.co/images/logo.png",
    "dark": "https://continum.co/images/white.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@continum.co"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://app.continum.co"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/continum-agency"
    }
  }
}